MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 1629006893}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 4c9619736cf84994586dfe76e5c486f7, type: 3}
  m_Name: 
  m_EditorClassIdentifier: 
  step: 0
  enableTutorial: 0
  dialogue: {fileID: 259310045}
  introLines:
  - speaker: 0
    speakerName: '?'
    text: "(\uB610\uAC01..\uB610\uAC01..\uB610\uAC01\uB610\uAC01 \uAD6C\uB450\uC18C\uB9AC\uAC00
      \uB2E4\uAE09\uD558\uAC8C \uB4E4\uB824\uC628\uB2E4.)"
    portrait: {fileID: 0}
    leftIllustration: {fileID: 0}
    rightIllustration: {fileID: 21300000, guid: 428d5418a60b025459b86d0815076437, type: 3}
    hasChoice: 0
    choices: []
    nextIndex: -1
  - speaker: 0
    speakerName: "\uB300\uC0AC\uC81C"
    text: "\uD788\uC2A4\uD1A0\uB9AC\uC544! (\uAC70\uCE5C \uC228\uC744 \uBAB0\uC544\uC26C\uBA70)
      \uBC29\uAE08... \uC2E0\uC758 \uBAA9\uC18C\uB9AC\uB97C \uB4E4\uC5C8\uC2B5\uB2C8\uB2E4."
    portrait: {fileID: 0}
    leftIllustration: {fileID: 21300000, guid: 3131b7f88d926b04792e89c1edf4b41e, type: 3}
    rightIllustration: {fileID: 21300000, guid: 428d5418a60b025459b86d0815076437, type: 3}
    hasChoice: 0
    choices: []
    nextIndex: -1
  - speaker: 1
    speakerName: "\uD788\uC2A4\uD1A0\uB9AC\uC544"
    text: "\uB124? \uC2E0\uD0C1\uC774\uB77C\uAD6C\uC694?"
    portrait: {fileID: 0}
    leftIllustration: {fileID: 21300000, guid: 3131b7f88d926b04792e89c1edf4b41e, type: 3}
    rightIllustration: {fileID: 21300000, guid: 428d5418a60b025459b86d0815076437, type: 3}
    hasChoice: 0
    choices: []
    nextIndex: -1
  - speaker: 0
    speakerName: "\uB300\uC0AC\uC81C"
    text: "\uC77C\uB2E8 \uC655\uAD81\uC5D4 \uC804\uB839\uC774 \uC18C\uC2DD\uC744
      \uC804\uB2EC\uD558\uACE0 \uC788\uC744\uAC81\uB2C8\uB2E4."
    portrait: {fileID: 0}
    leftIllustration: {fileID: 21300000, guid: 3131b7f88d926b04792e89c1edf4b41e, type: 3}
    rightIllustration: {fileID: 21300000, guid: 428d5418a60b025459b86d0815076437, type: 3}
    hasChoice: 0
    choices: []
    nextIndex: -1
  - speaker: 0
    speakerName: "\uB300\uC0AC\uC81C"
    text: "\uC5EC\uAE30\uC11C \uD560 \uC774\uC57C\uAE30\uB294 \uC544\uB2C8\uB2C8
      \uC131\uB2F9\uC73C\uB85C \uC774\uB3D9\uD558\uC8E0."
    portrait: {fileID: 0}
    leftIllustration: {fileID: 21300000, guid: 3131b7f88d926b04792e89c1edf4b41e, type: 3}
    rightIllustration: {fileID: 21300000, guid: 428d5418a60b025459b86d0815076437, type: 3}
    hasChoice: 0
    choices: []
    nextIndex: -1
  templeLines:
  - speaker: 0
    speakerName: "\uB300\uC0AC\uC81C"
    text: "\uD788\uC2A4\uD1A0\uB9AC\uC544 \uB2D8, \uC774\uC81C\uC57C \uB9D0\uC500
      \uB4DC\uB9B4 \uC218 \uC788\uACA0\uAD70\uC694."
    portrait: {fileID: 0}
    leftIllustration: {fileID: 21300000, guid: 3131b7f88d926b04792e89c1edf4b41e, type: 3}
    rightIllustration: {fileID: 21300000, guid: 428d5418a60b025459b86d0815076437, type: 3}
    hasChoice: 0
    choices: []
    nextIndex: -1
  - speaker: 0
    speakerName: "\uB300\uC0AC\uC81C"
    text: "\uC81C\uAC00 \uB4E4\uC740 \uBC14\uB85C\uB294 \uC2E0\uAED8\uC11C \uC9C1\uC811,
      \uC870\uB9CC\uAC04 \uC6A9\uB4E4\uC774 \uC7AC\uC559\uC744 \uBAB0\uACE0 \uC62C
      \uAC83\uC774\uB77C\uACE0 \uB9D0\uC500\r\n\uD558\uC168\uC2B5\uB2C8\uB2E4."
    portrait: {fileID: 0}
    leftIllustration: {fileID: 21300000, guid: 3131b7f88d926b04792e89c1edf4b41e, type: 3}
    rightIllustration: {fileID: 21300000, guid: 428d5418a60b025459b86d0815076437, type: 3}
    hasChoice: 0
    choices: []
    nextIndex: -1
  - speaker: 0
    speakerName: "\uB300\uC0AC\uC81C"
    text: "\uACE7 \uCD9C\uC815\uC744 \uB0B4\uB9AC\uC2E4 \uAC83 \uAC19\uC73C\uB2C8
      \uC900\uBE44\uB97C \uD574\uB450\uB294 \uAC8C \uC88B\uC744 \uAC83 \uAC19\uAD70\uC694."
    portrait: {fileID: 0}
    leftIllustration: {fileID: 21300000, guid: 3131b7f88d926b04792e89c1edf4b41e, type: 3}
    rightIllustration: {fileID: 21300000, guid: 428d5418a60b025459b86d0815076437, type: 3}
    hasChoice: 0
    choices: []
    nextIndex: -1
  - speaker: 0
    speakerName: "\uB300\uC0AC\uC81C"
    text: "\uADF8 \uC131\uC720\uBB3C\uC774 \uC804\uC7A5\uC5D0\uC11C \uB3C4\uC6C0\uC774
      \uB418\uAE38 \uBC14\uB78D\uB2C8\uB2E4."
    portrait: {fileID: 0}
    leftIllustration: {fileID: 21300000, guid: 3131b7f88d926b04792e89c1edf4b41e, type: 3}
    rightIllustration: {fileID: 21300000, guid: 428d5418a60b025459b86d0815076437, type: 3}
    hasChoice: 0
    choices: []
    nextIndex: -1
  - speaker: 0
    speakerName: "\uB300\uC0AC\uC81C"
    text: "\uBC16\uC5D0\uC11C \uC804\uB839\uC774 \uBD80\uB974\uB294\uAD70\uC694.
      \uC870\uC2EC\uD788 \uB2E4\uB140\uC624\uC2DC\uAE38."
    portrait: {fileID: 0}
    leftIllustration: {fileID: 21300000, guid: 3131b7f88d926b04792e89c1edf4b41e, type: 3}
    rightIllustration: {fileID: 21300000, guid: 428d5418a60b025459b86d0815076437, type: 3}
    hasChoice: 0
    choices: []
    nextIndex: -1
  beforeRoyalLines:
  - speaker: 0
    speakerName: "\uC81C1\uAE30\uC0AC\uB2E8\uC7A5"
    text: "\uD788\uC2A4\uD1A0\uB9AC\uC544 \uB2E8\uC7A5, \uB9C8\uCE68 \uC798 \uC654\uB124."
    portrait: {fileID: 0}
    leftIllustration: {fileID: 21300000, guid: 35ed3daaac767e944bae827eb97e72ee, type: 3}
    rightIllustration: {fileID: 21300000, guid: 428d5418a60b025459b86d0815076437, type: 3}
    hasChoice: 0
    choices: []
    nextIndex: -1
  - speaker: 0
    speakerName: "\uC81C1\uAE30\uC0AC\uB2E8\uC7A5"
    text: "\uD3D0\uD558\uAED8\uC11C \uC774\uBBF8 \uBAA8\uB4E0 \uB2E8\uC7A5\uB4E4\uC744
      \uC18C\uC9D1\uD558\uC168\uB124.\n\uC0C1\uD669\uC774 \uC88B\uC9C0 \uC54A\uC544."
    portrait: {fileID: 0}
    leftIllustration: {fileID: 21300000, guid: 35ed3daaac767e944bae827eb97e72ee, type: 3}
    rightIllustration: {fileID: 21300000, guid: 428d5418a60b025459b86d0815076437, type: 3}
    hasChoice: 0
    choices: []
    nextIndex: -1
  - speaker: 0
    speakerName: "\uC81C1\uAE30\uC0AC\uB2E8\uC7A5"
    text: "\uBD84\uC704\uAE30\uAC00 \uC2EC\uC0C1\uCE58 \uC54A\uC740 \uB4EF \uD558\uB124\uB9CC,
      \uC790\uB124\uAC00 \uC788\uC73C\uB2C8 \uB4E0\uB4E0\uD558\uAD6C\uB9CC."
    portrait: {fileID: 0}
    leftIllustration: {fileID: 21300000, guid: 35ed3daaac767e944bae827eb97e72ee, type: 3}
    rightIllustration: {fileID: 21300000, guid: 428d5418a60b025459b86d0815076437, type: 3}
    hasChoice: 0
    choices: []
    nextIndex: -1
  - speaker: 0
    speakerName: "\uC81C1\uAE30\uC0AC\uB2E8\uC7A5"
    text: "\uC774\uB7F4\uB54C\uAC00 \uC544\uB2C8\uC9C0.\n\uC5B4\uC11C \uD3D0\uD558\uAED8
      \uAC00\uBCF4\uB3C4\uB85D\uD558\uC9C0."
    portrait: {fileID: 0}
    leftIllustration: {fileID: 21300000, guid: 35ed3daaac767e944bae827eb97e72ee, type: 3}
    rightIllustration: {fileID: 21300000, guid: 428d5418a60b025459b86d0815076437, type: 3}
    hasChoice: 0
    choices: []
    nextIndex: -1
  royalLines:
  - speaker: 0
    speakerName: "\uC655"
    text: "\uAE30\uC0AC\uB2E8\uC7A5\uB4E4\uC740 \uB4E4\uC5B4\uB77C.\n\uD604\uC7AC
      \uC2E0\uD0C1\uC774 \uB0B4\uB824\uC654\uB2E4."
    portrait: {fileID: 0}
    leftIllustration: {fileID: 21300000, guid: 60c1f0829f9e6354bbb7507a7370b558, type: 3}
    rightIllustration: {fileID: 0}
    hasChoice: 0
    choices: []
    nextIndex: -1
  - speaker: 0
    speakerName: "\uC655"
    text: "\uD558\uB298\uC758 \uB73B\uC73C\uB85C \uC6B0\uB9AC \uC778\uB958\uC758
      \uC874\uC18D\uC744 \uAC78\uACE0 \uC7AC\uC559\uC758 \uC2F9\uC744 \uBBF8\uB9AC
      \uCE58\uC790\uB294 \uAC83\uC774 \uC9D0\uC758 \uD310\uB2E8\uC774\uB2E4."
    portrait: {fileID: 0}
    leftIllustration: {fileID: 21300000, guid: 60c1f0829f9e6354bbb7507a7370b558, type: 3}
    rightIllustration: {fileID: 0}
    hasChoice: 0
    choices: []
    nextIndex: -1
  - speaker: 0
    speakerName: "\uC655"
    text: "\uADF8\uB7EC\uB098 \uC6B0\uB9AC\uB294 \uC544\uC9C1 \uADF8\uB4E4\uC774
      \uC800 \uB192\uC740 \uC544\uB974\uCE74\uB514\uC544\uC5D0 \uAC70\uC8FC\uD558\uACE0
      \uC788\uB2E4\uB294 \uAC83\uB9CC \uC54C\uACE0 \uC788\uC744\uBFD0..."
    portrait: {fileID: 0}
    leftIllustration: {fileID: 21300000, guid: 60c1f0829f9e6354bbb7507a7370b558, type: 3}
    rightIllustration: {fileID: 0}
    hasChoice: 0
    choices: []
    nextIndex: -1
  - speaker: 0
    speakerName: "\uC655"
    text: "\uAC00\uB294 \uAE38\uC5D0 \uB300\uD55C \uC815\uBCF4\uAC00 \uC5C6\uC73C\uB098,
      \uD56D\uC0C1 \uADF8\uB807\uB4EF \uD558\uB298\uC758 \uB208\uC774 \uADF8\uB300\uB4E4\uC744
      \uC778\uB3C4\uD560 \uAC83\uC774\uB2E4."
    portrait: {fileID: 0}
    leftIllustration: {fileID: 21300000, guid: 60c1f0829f9e6354bbb7507a7370b558, type: 3}
    rightIllustration: {fileID: 0}
    hasChoice: 0
    choices: []
    nextIndex: -1
  - speaker: 0
    speakerName: "\uC655"
    text: "\uADF8\uB7EC\uB2C8 \uADF8\uB300\uB4E4\uC740 \uAE30\uC0AC\uB2E8\uC744 \uC7AC\uD3B8\uC131\uD558\uC5EC
      \uC815\uCC30\uACFC \uB3D9\uC2DC\uC5D0 \uCD9C\uC815\uD558\uB77C."
    portrait: {fileID: 0}
    leftIllustration: {fileID: 21300000, guid: 60c1f0829f9e6354bbb7507a7370b558, type: 3}
    rightIllustration: {fileID: 0}
    hasChoice: 0
    choices: []
    nextIndex: -1
  - speaker: 0
    speakerName: "\uC81C1\uAE30\uC0AC\uB2E8\uC7A5"
    text: "\uB0B4\uAC00 \uAC04\uB2E8\uD788 \uC124\uBA85\uD574\uC8FC\uC9C0. \uC6B0\uC120
      \uC6B0\uCE21\uC744 \uBCF4\uAC8C\uB098.\n\uC790\uB124\uC758 \uBD80\uB984\uC744
      \uAE30\uB2E4\uB9AC\uB294 \uAE30\uC0AC\uB2E8 \uD6C4\uBCF4\uC0DD\uB4E4\uC774
      \uBCF4\uC77C\uAC78\uC138."
    portrait: {fileID: 0}
    leftIllustration: {fileID: 21300000, guid: 35ed3daaac767e944bae827eb97e72ee, type: 3}
    rightIllustration: {fileID: 0}
    hasChoice: 0
    choices: []
    nextIndex: -1
  - speaker: 0
    speakerName: "\uC81C1\uAE30\uC0AC\uB2E8\uC7A5"
    text: "\uAC01 \uAE30\uC0AC\uC758 \uB2A5\uB825\uC744 \uD655\uC778\uD558\uACE0,
      \uC790\uB124\uC758 \uC804\uB7B5\uC5D0 \uB9DE\uB294 \uC774\uB4E4\uC744 \uACE0\uC6A9\uD574
      \uAE30\uC0AC\uB2E8\uC744 \uD3B8\uC131\uD574\uBCF4\uAC8C\uB098."
    portrait: {fileID: 0}
    leftIllustration: {fileID: 21300000, guid: 35ed3daaac767e944bae827eb97e72ee, type: 3}
    rightIllustration: {fileID: 0}
    hasChoice: 0
    choices: []
    nextIndex: -1
  - speaker: 0
    speakerName: "\uC81C1\uAE30\uC0AC\uB2E8\uC7A5"
    text: "\uC9C0\uAE08\uC740 \uD6C8\uB828 \uB2E8\uACC4\uC774\uB2C8, \uB9C8\uC74C\uC5D0
      \uAC00\uB294 \uAE30\uC0AC 40\uBA85\uC73C\uB85C \uC815\uC608\uBD80\uB300\uB97C
      \uAFB8\uB824\uBCF4\uAC8C."
    portrait: {fileID: 0}
    leftIllustration: {fileID: 21300000, guid: 35ed3daaac767e944bae827eb97e72ee, type: 3}
    rightIllustration: {fileID: 0}
    hasChoice: 0
    choices: []
    nextIndex: -999
  - speaker: 0
    speakerName: "\uC81C1\uAE30\uC0AC\uB2E8\uC7A5"
    text: "\uC790\uB124, \uC2E4\uC804 \uCD9C\uC815\uC740 \uCC98\uC74C\uC774\uC9C0
      \uC54A\uB098."
    portrait: {fileID: 0}
    leftIllustration: {fileID: 21300000, guid: 35ed3daaac767e944bae827eb97e72ee, type: 3}
    rightIllustration: {fileID: 21300000, guid: 428d5418a60b025459b86d0815076437, type: 3}
    hasChoice: 0
    choices: []
    nextIndex: -1
  - speaker: 0
    speakerName: "\uC81C1\uAE30\uC0AC\uB2E8\uC7A5"
    text: "\uB098\uAC00\uAE30 \uC804 \uC8FC\uC758\uD560 \uC810\uB4E4\uC5D0 \uB300\uD574
      \uBBF8\uB9AC \uC54C\uB824\uC8FC\uC9C0."
    portrait: {fileID: 0}
    leftIllustration: {fileID: 21300000, guid: 35ed3daaac767e944bae827eb97e72ee, type: 3}
    rightIllustration: {fileID: 21300000, guid: 428d5418a60b025459b86d0815076437, type: 3}
    hasChoice: 0
    choices: []
    nextIndex: -1
  - speaker: 0
    speakerName: "\uC81C1\uAE30\uC0AC\uB2E8\uC7A5"
    text: "\uC6B0\uC120 \uD6C8\uB828\uC7A5\uC73C\uB85C \uB530\uB77C\uC624\uAC8C\uB098.
      \uC131\uBB38 \uBC16 \uBBF8\uAD81\uC785\uAD6C\uC5D0\uC11C \uAE30\uB2E4\uB9AC\uACE0
      \uC788\uACA0\uB124."
    portrait: {fileID: 0}
    leftIllustration: {fileID: 21300000, guid: 35ed3daaac767e944bae827eb97e72ee, type: 3}
    rightIllustration: {fileID: 21300000, guid: 428d5418a60b025459b86d0815076437, type: 3}
    hasChoice: 0
    choices: []
    nextIndex: -1
  battleStartLines:
  - speaker: 0
    speakerName: "\uC81C1\uAE30\uC0AC\uB2E8\uC7A5"
    text: "\uC804\uD22C\uC5D0 \uB300\uD574 \uC54C\uB824\uC8FC\uC9C0. \uC2B9\uB9AC\uC870\uAC74\uC740
      \uAC04\uB2E8\uD558\uB124. \uC0C1\uB300 \uBD80\uB300\uB97C \uC804\uBA78\uC2DC\uD0A4\uBA74
      \uB05D\uC774\uC9C0."
    portrait: {fileID: 0}
    leftIllustration: {fileID: 21300000, guid: 35ed3daaac767e944bae827eb97e72ee, type: 3}
    rightIllustration: {fileID: 0}
    hasChoice: 0
    choices: []
    nextIndex: -1
  - speaker: 0
    speakerName: "\uC81C1\uAE30\uC0AC\uB2E8\uC7A5"
    text: "\uBA85\uC2EC\uD558\uAC8C. \uC790\uB124\uAC00 \uC774\uB044\uB294 \uAE30\uC0AC\uB2E8
      \uC790\uCCB4\uAC00 \uACE7 \uC790\uB124\uC758 \uC0DD\uBA85\uB825\uC77C\uC138.
      \uC790\uB124\uAC00 \uACF5\uACA9\uBC1B\uC744 \uB54C, \uAE30\uC0AC\uB2E8\uC740
      \uC790\uB124\uB97C \uB300\uC2E0\uD574 \uD76C\uC0DD\uD558\uC5EC \uBB18\uC9C0\uB85C
      \uBCF4\uB0B4\uC9C8 \uAC83\uC774\uB124."
    portrait: {fileID: 0}
    leftIllustration: {fileID: 21300000, guid: 35ed3daaac767e944bae827eb97e72ee, type: 3}
    rightIllustration: {fileID: 0}
    hasChoice: 0
    choices: []
    nextIndex: -1
  - speaker: 0
    speakerName: "\uC81C1\uAE30\uC0AC\uB2E8\uC7A5"
    text: "\uB9E4 \uD134 \uCD5C\uB300\uC804\uC220\uB825\uC774 1\uC529 \uC99D\uAC00\uD558\uBA70,
      \uC18C\uBAA8\uD55C \uC804\uC220\uB825\uC740 \uC790\uC2E0\uC758 \uD134\uC5D0
      \uB2E4\uC2DC \uCC44\uC6CC\uC9C8 \uAC78\uC138."
    portrait: {fileID: 0}
    leftIllustration: {fileID: 21300000, guid: 35ed3daaac767e944bae827eb97e72ee, type: 3}
    rightIllustration: {fileID: 0}
    hasChoice: 0
    choices: []
    nextIndex: -1
  - speaker: 0
    speakerName: "\uC81C1\uAE30\uC0AC\uB2E8\uC7A5"
    text: "\uC804\uC220\uB825\uC744 \uC18C\uBAA8\uD558\uC5EC \uC790\uB124\uAC00 \uD3B8\uC131\uD55C
      \uAE30\uC0AC\uB2E8\uC6D0\uC911 \uAC00\uB2A5\uD55C \uBCD1\uB825\uC744 \uC804\uC7A5\uC5D0
      \uBC30\uCE58\uD574\uBCF4\uAC8C."
    portrait: {fileID: 0}
    leftIllustration: {fileID: 21300000, guid: 35ed3daaac767e944bae827eb97e72ee, type: 3}
    rightIllustration: {fileID: 0}
    hasChoice: 0
    choices: []
    nextIndex: -1
  firstCardLines:
  - speaker: 0
    speakerName: "\uC81C1\uAE30\uC0AC\uB2E8\uC7A5"
    text: "\uC804\uC7A5\uC5D0 \uBC30\uCE58\uD55C \uAE30\uC0AC\uB2E8\uC73C\uB85C \uC801\uC744
      \uACF5\uACA9\uD560\uB550 \uC77C\uBC29\uC801\uC73C\uB85C \uB54C\uB9AC\uB294
      \uAC83\uC774 \uC544\uB2CC, \uC11C\uB85C\uC758 \uACF5\uACA9\uB825\uACFC \uCCB4\uB825\uC744
      \uB098\uB204\uB294 \uC804\uD22C\uB77C\uB294 \uAC83\uC744 \uBA85\uC2EC\uD558\uAC8C."
    portrait: {fileID: 0}
    leftIllustration: {fileID: 21300000, guid: 35ed3daaac767e944bae827eb97e72ee, type: 3}
    rightIllustration: {fileID: 0}
    hasChoice: 0
    choices: []
    nextIndex: -1
  - speaker: 0
    speakerName: "\uC81C1\uAE30\uC0AC\uB2E8\uC7A5"
    text: "\uB610\uD55C \uAE30\uC0AC\uB4E4\uC740 \uC804\uC7A5\uC5D0 \uBC30\uCE58\uB41C
      \uCC28\uB840\uC5D0\uB294 \uACF5\uACA9\uD560 \uC21C \uC5C6\uB124. \uC228\uC744
      \uACE0\uB97C \uC2DC\uAC04\uC774 \uD544\uC694\uD558\uB2C8 \uBC30\uCE58\uB41C
      \uB2E4\uC74C \uD134\uBD80\uD130 \uACF5\uACA9\uC774 \uAC00\uB2A5\uD560 \uAC78\uC138."
    portrait: {fileID: 0}
    leftIllustration: {fileID: 21300000, guid: 35ed3daaac767e944bae827eb97e72ee, type: 3}
    rightIllustration: {fileID: 0}
    hasChoice: 0
    choices: []
    nextIndex: -1
  - speaker: 0
    speakerName: "\uC81C1\uAE30\uC0AC\uB2E8\uC7A5"
    text: "\uC790, \uC774\uC81C \uC798 \uC774\uD574\uD588\uB294\uC9C0 \uBAA8\uC758\uC804\uC744
      \uCE58\uB904 \uBCF4\uB3C4\uB85D \uD558\uC9C0. \uD55C\uBC88 \uB364\uBCBC\uBCF4\uAC8C\uB098."
    portrait: {fileID: 0}
    leftIllustration: {fileID: 21300000, guid: 35ed3daaac767e944bae827eb97e72ee, type: 3}
    rightIllustration: {fileID: 0}
    hasChoice: 0
    choices: []
    nextIndex: -1
  winLines:
  - speaker: 0
    speakerName: "\uC81C1\uAE30\uC0AC\uB2E8\uC7A5"
    text: "\uB300\uB2E8\uD558\uAD70! \uC774\uC81C \uBC14\uB85C \uC2E4\uC804\uC73C\uB85C
      \uB098\uAC00\uB3C4 \uC190\uC0C9\uC774 \uC5C6\uACA0\uC5B4. \uC790\uB124\uC758
      \uC120\uD0DD\uC744 \uBC1B\uC740 \uAE30\uC0AC\uB4E4\uACFC \uD568\uAED8 \uC601\uAD11\uC2A4\uB7EC\uC6B4
      \uCD9C\uC815\uC744 \uC2DC\uC791\uD558\uAC8C\uB098."
    portrait: {fileID: 0}
    leftIllustration: {fileID: 21300000, guid: 35ed3daaac767e944bae827eb97e72ee, type: 3}
    rightIllustration: {fileID: 0}
    hasChoice: 0
    choices: []
    nextIndex: -1
  - speaker: 0
    speakerName: "\uC81C1\uAE30\uC0AC\uB2E8\uC7A5"
    text: "\uD639\uC5EC\uB098 \uC804\uC220 \uC5F0\uC2B5 \uC0C1\uB300\uAC00 \uD544\uC694\uD558\uB2E4\uBA74
      \uC5B8\uC81C\uB4E0 \uD6C8\uB828\uC7A5\uC73C\uB85C \uCC3E\uC544\uC624\uAC8C.
      \uB09C \uD3D0\uD558\uC640 \uC774\uACF3 \uB9C8\uC744\uC744 \uC9C0\uD0A4\uACE0
      \uC788\uC744 \uD14C\uB2C8 \uB9D0\uC77C\uC138."
    portrait: {fileID: 0}
    leftIllustration: {fileID: 21300000, guid: 35ed3daaac767e944bae827eb97e72ee, type: 3}
    rightIllustration: {fileID: 0}
    hasChoice: 0
    choices: []
    nextIndex: -1
  loseLines:
  - speaker: 0
    speakerName: "\uC81C1\uAE30\uC0AC\uB2E8\uC7A5"
    text: "\uD558\uD558\uD558! \uBBF8\uC548\uD558\uB124, \uBAA8\uC758\uC804\uC778\uB370
      \uB0B4\uAC00 \uD798\uC870\uC808\uC744 \uBABB \uD588\uAD6C\uB9CC. \uD558\uC9C0\uB9CC
      \uC774\uC815\uB3C4 \uAE30\uC138\uB77C\uBA74 \uC2E4\uC804\uC5D0\uC11C\uB3C4
      \uCDA9\uBD84\uD788 \uD65C\uC57D\uD560\uAC70\uB77C \uBBFF\uB124."
    portrait: {fileID: 0}
    leftIllustration: {fileID: 21300000, guid: 35ed3daaac767e944bae827eb97e72ee, type: 3}
    rightIllustration: {fileID: 0}
    hasChoice: 0
    choices: []
    nextIndex: -1
  - speaker: 0
    speakerName: "\uC81C1\uAE30\uC0AC\uB2E8\uC7A5"
    text: "\uBD88\uC548\uD558\uB2E4\uBA74 \uD55C\uBC88 \uB354 \uB300\uB828\uD574\uBCF4\uACA0\uB098?
      \uC544\uB2C8\uBA74 \uBC14\uB85C \uCD9C\uC815\uD574\uB3C4 \uC790\uB128 \uCDA9\uBD84\uD788
      \uD574\uB0BC \uC218 \uC788\uC744\uAC8C\uC57C."
    portrait: {fileID: 0}
    leftIllustration: {fileID: 21300000, guid: 35ed3daaac767e944bae827eb97e72ee, type: 3}
    rightIllustration: {fileID: 0}
    hasChoice: 0
    choices: []
    nextIndex: -1
